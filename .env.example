# Vercel Deploy Hook URL (get from Vercel project settings → Git → Deploy Hooks)
VERCEL_DEPLOY_HOOK_URL=https://api.vercel.com/v1/integrations/deploy/prj_xxx/yyy

# Optional: GitHub integration for auto-commit/push
GITHUB_TOKEN=ghp_xxx
GITHUB_REPO_OWNER=your-org
GITHUB_REPO_NAME=your-repo

# Optional: OpenAI / AI provider key (for future AI-powered steps)
OPENAI_API_KEY=sk-xxx

# App base URL (used for internal API calls in workflows)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── AI / LLM Integration ──────────────────────────────────────────────────────

# Anthropic API key — required for POST /api/ai (Claude integration)
# Get yours at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Optional: override the default Claude model
# Default: claude-3-5-sonnet-20241022
CLAUDE_MODEL=claude-3-5-sonnet-20241022

# ── Guardrails & Auth ─────────────────────────────────────────────────────────

# Secret key used to sign JWT tokens for agent endpoints
AGENT_SECRET_KEY=your-secret-key-here

# API key alternative to JWT (prefix: sk-)
AGENT_API_KEY=sk-your-api-key-here

# Whether to require authentication for agent endpoints (default: false)
AGENT_REQUIRE_AUTH=false

# Rate limiting
AGENT_MAX_REQUESTS_PER_MINUTE=60
AGENT_MAX_EXECUTIONS_PER_HOUR=100
AGENT_MAX_TOKENS_PER_DAY=1000000

# File size limit in MB (default: 1)
AGENT_FILE_SIZE_LIMIT_MB=1

# Path to the audit log file (default: .logs/audit.jsonl)
AUDIT_LOG_PATH=.logs/audit.jsonl
